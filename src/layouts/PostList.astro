---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import {
  getPostDate,
  getarticles,
  getarticlesByTag,
  getSortedarticles,
  formatDate
} from "@utils";

export interface Props {
  tag?: string;
}

const { tag } = Astro.props;

const title = "Articles";

const articles = await getarticles();
const filteredarticles = tag ? getarticlesByTag(articles, tag) : articles;
const sortedarticles = getSortedarticles(filteredarticles);

const groupedByYear = sortedarticles.reduce((acc, item) => {
  const year = getPostDate(item.id).slice(0, 4);
  (acc[year] ||= []).push(item);
  return acc;
}, {} as Record<string, typeof sortedarticles>);

const years = Object.keys(groupedByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout title={`${title} - ${SITE.title}`} activePage={"articles"}>
  <main class="articles-shell">
    <section class="articles-hero">
      <div>
        <p class="eyebrow">/articles</p>
        <h1>Notes from the build log.</h1>
      </div>
    </section>

    <section class="articles-grid">
      {
        years.map((year) => (
          <div class="year-block">
            <div class="year-label">{year}</div>
            <div class="year-grid">
              {groupedByYear[year].map((item) => (
                <a class="post-card" href={`/articles/${item.id}`} transition:name={item.id}>
                  <div class="post-card__date">{formatDate(getPostDate(item.id), 0)}</div>
                  <h3 class="post-card__title">{item.data.title}</h3>
                  <div class="post-card__arrow" aria-hidden="true">→</div>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </section>
  </main>

  <style>
    .articles-shell {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 1.25rem 2.5rem;
      border: none;
      border-radius: 0;
      background: transparent;
    }

    .articles-hero {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.8rem;
      color: #928374;
      margin: 0 0 0.2rem 0;
    }

    .lede {
      color: #bdae93;
      margin: 0.2rem 0 0;
      max-width: 38rem;
    }

    .articles-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .year-block {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .year-label {
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      color: #928374;
    }

    .year-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }

    .post-card {
      position: relative;
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto;
      column-gap: 0.75rem;
      row-gap: 0.3rem;
      padding: 1rem 1.05rem;
      color: #ebdbb2;
      text-decoration: none;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: #282828;
      box-shadow: none;
      transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
    }

    .post-card::before {
      content: none;
    }

    .post-card:hover {
      color: #ebdbb2;
      border-color: rgba(255, 255, 255, 0.16);
      background: #2d2d2d;
      box-shadow: none;
    }

    .post-card__date {
      color: #7c6f64;
      font-size: 0.9rem;
      grid-column: 1 / 2;
    }

    .post-card__title {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      grid-column: 1 / 2;
      color: #ebdbb2;
    }

    .post-card__arrow {
      color: #a89984;
      font-weight: 700;
      align-self: center;
      grid-row: 1 / -1;
      grid-column: 2 / 3;
    }

    @media (max-width: 720px) {
      .articles-hero {
        flex-direction: column;
        align-items: flex-start;
      }

    }
  </style>
</Layout>
