---
import { frontmatter, Content } from "@content/about/index.md";
import { SITE } from "@config";
import type { SocialItem } from "@types";
import Links from "@components/Links.astro";
import FlipImage from "@components/FlipImage.astro";
import Layout from "@layouts/Layout.astro";

interface Frontmatter {
  name: string;
  subname?: string;
  avatarFront?: string;
  avatarBack?: string;
  tltr?: string;
  socials: SocialItem[];
}

const { name, subname, avatarFront, avatarBack, tltr, socials } =
  frontmatter as Frontmatter;
---

<Layout class="about" title={`About - ${SITE.title}`}>
  <section class="landing">
    <div class="landing__grid">
      <div class="landing__frame">
        <p class="landing__badge">$ whoami</p>
        <h1 class="landing__title">
          {name}
          {subname && <span class="landing__sub"> ({subname})</span>}
        </h1>
        <div class="landing__links">
          <Links socials={socials} />
        </div>
        {tltr && <p class="landing__lede">{tltr}</p>}

        <div class="landing__actions">
          <a class="cta cta-primary" href="https://vyrox.dev">Founding Vyrox Security &rarr;</a>
          <a class="cta cta-ghost" href="/builds">See builds</a>
          <a class="cta cta-ghost" href="/journal">Journal</a>
        </div>

        <div class="current-mode-inline">
          <p class="meta-label">Current mode</p>
          <h3 class="meta-title">Shipping & writing daily</h3>
          <p class="meta-copy">Carving ideas into products and field notes - quietly, consistently.</p>
        </div>

      </div>

      <div class="landing__meta">
        {avatarFront && (
          <div class="landing__avatar">
            <FlipImage front={avatarFront} back={avatarBack} alt="avatar" />
          </div>
        )}

        <div class="meta-card">
          <p class="meta-label">Where to dive in</p>
          <ul class="meta-list">
            <li><span class="i-uil:arrow-right" aria-hidden="true" /> Latest build logs in <a href="/journal" class="text-[#83a598] hover:text-[#fbf1c7] transition-colors underline decoration-[#83a598]/30 underline-offset-4">/journal</a></li>
            <li><span class="i-uil:arrow-right" aria-hidden="true" /> Long-form notes in <a href="/articles" class="text-[#83a598] hover:text-[#fbf1c7] transition-colors underline decoration-[#83a598]/30 underline-offset-4">/articles</a></li>
            <li><span class="i-uil:arrow-right" aria-hidden="true" /> Active experiments in <a href="/builds" class="text-[#83a598] hover:text-[#fbf1c7] transition-colors underline decoration-[#83a598]/30 underline-offset-4">/builds</a></li>
          </ul>
        </div>

        <div class="meta-card">
          <p class="meta-label">Current reading</p>
          <ul class="meta-list">
            <li><span class="i-uil:arrow-right" aria-hidden="true" /> Black Hat Rust - Sylvain Kerkour</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="about-body">
    <section class="vyrox-spotlight relative overflow-hidden" aria-label="Vyrox Security Spotlight">
      <div class="spotlight-content relative z-10">
        <div class="spotlight-header">
          <span class="i-ph:terminal-window-duotone text-[#83a598] text-lg mb-0.5 animate-pulse"></span>
          <p class="meta-label spotlight-label">Currently Building</p>
        </div>
        
        <h2 class="spotlight-title">Vyrox Security</h2>
        
        <p class="spotlight-desc">
          Memory-safe, autonomous AI SOC infrastructure. We build agents that investigate threats <span class="spotlight-highlight">deterministically</span>.
        </p>
        

        
        <div class="spotlight-actions">
          <a class="cta cta-primary spotlight-cta" href="https://vyrox.dev">
            Access the Platform
            <span class="i-ph:arrow-right-bold"></span>
          </a>
          <a class="cta cta-ghost spotlight-ghost" href="mailto:keirsalterego@gmail.com">
            Request Pilot
          </a>
        </div>
      </div>
    </section>

    <section class="contrib contrib--mid" aria-label="GitHub contributions">
      <h2 class="contrib__title">Contributions</h2>
      <div class="contrib__graph-wrap">
        <img
          class="contrib__graph"
          src="https://ghchart.rshah.org/keirsalterego"
          alt="GitHub contribution graph"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <div class="about-card">
      <Content />
    </div>
  </section>

  <style>
    .landing {
      margin-top: 1rem;
      margin-bottom: 2rem;
    }

    .landing__grid {
      display: grid;
      grid-template-columns: 1.35fr 1fr;
      gap: 1.25rem;
      align-items: stretch;
    }

    .landing__frame {
      position: relative;
      padding: 1.6rem 1.7rem;
      border-radius: 0;
      border: none;
      background: transparent;
      box-shadow: none;
      overflow: hidden;
    }

    .landing__frame::after {
      content: none;
    }

    .landing__frame > * {
      position: relative;
      z-index: 1;
    }

    .landing__badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.32rem 0.75rem;
      margin: 0 0 0.7rem 0;
      border-radius: 0;
      border: none;
      background: transparent;
      box-shadow: none;
      color: #c1ae8b;
      font-size: 0.95rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .landing__title {
      margin: 0 0 0.35rem 0;
      font-size: 2.5rem;
      letter-spacing: 0.01em;
    }

    .landing__sub {
      color: #7c6f64;
      font-size: 1rem;
    }

    .landing__lede {
      margin: 0 0 1.2rem 0;
      color: #bdae93;
      max-width: 46ch;
      line-height: 1.6;
    }

    .landing__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
      margin-bottom: 1.1rem;
    }

    .cta {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.34rem 0.68rem;
      border-radius: 7px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.09);
      transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
    }

    .cta-primary {
      color: #ebdbb2;
      background: #272727;
      box-shadow: none;
    }

    .cta-primary:hover {
      border-color: rgba(255, 255, 255, 0.16);
      background: #2d2d2d;
      box-shadow: none;
    }

    .cta-ghost {
      color: #d5c4a1;
      background: #232323;
      box-shadow: none;
    }

    .cta-ghost:hover {
      border-color: rgba(255, 255, 255, 0.14);
      background: #292929;
      box-shadow: none;
    }

    .landing__links {
      margin: 0.35rem 0 0.5rem;
    }

    .current-mode-inline {
      margin: 0.2rem 0 0.45rem;
      max-width: 48ch;
    }

    .vyrox-spotlight {
      max-width: 760px;
      margin: 2.5rem auto;
      padding: 1rem 1.1rem;
      background: transparent;
      border: none;
      text-align: left;
      position: relative;
    }
    


    .spotlight-header {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-bottom: 0.8rem;
    }

    .spotlight-label {
      margin: 0 !important;
      color: #bdae93;
    }

    .spotlight-title {
      margin: 0 0 1rem 0;
      font-size: 2.2rem;
      color: #fbf1c7;
      font-weight: 700;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    

    .spotlight-desc {
      color: #ebdbb2;
      margin-bottom: 1.5rem;
      line-height: 1.6;
      font-size: 1.1rem;
      max-width: 65ch;
    }
    
    .spotlight-highlight {
      color: #83a598;
      font-weight: 600;
    }
    
    .spotlight-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
    }
    
    .spotlight-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.34rem 0.68rem;
      border-radius: 7px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.09);
      transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
      background: #272727;
      color: #ebdbb2;
    }
    
    .spotlight-cta:hover {
      background: #2d2d2d;
      border-color: rgba(255, 255, 255, 0.16);
      color: #fbf1c7;
    }
    
    .spotlight-ghost {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.34rem 0.68rem;
      border-radius: 7px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.09);
      transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
      color: #d5c4a1;
      background: #232323;
    }
    
    .spotlight-ghost:hover {
      background: #292929;
      border-color: rgba(255, 255, 255, 0.14);
      color: #fbf1c7;
    }
    
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(184, 187, 38, 0.4); }
      70% { box-shadow: 0 0 0 6px rgba(184, 187, 38, 0); }
      100% { box-shadow: 0 0 0 0 rgba(184, 187, 38, 0); }
    }

    .contrib {
      margin-top: 1rem;
    }

    .contrib--mid {
      max-width: 760px;
      margin: 0 auto 1.25rem;
      width: 100%;
    }

    .contrib__title {
      margin: 0 0 0.6rem;
      font-size: 1.5rem;
      line-height: 1.35;
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    .contrib__graph-wrap {
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      overflow: hidden;
      background: #1f1f1f;
      padding: 0.55rem;
    }

    .contrib__graph {
      display: block;
      width: 100%;
      height: auto;
    }

    .landing__meta {
      display: grid;
      grid-template-rows: auto auto auto;
      gap: 0.9rem;
      align-content: start;
    }

    .landing__avatar {
      justify-self: end;
      width: 180px;
      height: 180px;
      border-radius: 0;
      padding: 0.8rem;
      border: none;
      background: transparent;
      box-shadow: none;
    }

    .meta-card {
      padding: 1rem 1.1rem;
      border-radius: 0;
      border: none;
      background: transparent;
      box-shadow: none;
    }

    .meta-label {
      margin: 0 0 0.35rem 0;
      color: #7c6f64;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-size: 0.85rem;
    }

    .meta-title {
      margin: 0 0 0.4rem 0;
      font-size: 1.15rem;
    }

    .meta-copy {
      margin: 0;
      color: #bdae93;
      line-height: 1.55;
    }

    .meta-list {
      margin: 0.2rem 0 0;
      padding-left: 0;
      list-style: none;
      display: grid;
      gap: 0.35rem;
      color: #d5c4a1;
    }

    .meta-list .i-uil:arrow-right {
      color: #a89984;
      margin-right: 0.4rem;
      font-size: 1rem;
      vertical-align: -0.1em;
    }

    .about-body {
      margin: 0 auto 2.5rem;
      max-width: 980px;
    }

    .about-card {
      padding: 1.25rem 1.4rem;
      border-radius: 0;
      border: none;
      background: transparent;
      box-shadow: none;
    }

    @media (max-width: 960px) {
      .landing__grid {
        grid-template-columns: 1fr;
      }

      .landing__meta {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        grid-template-rows: none;
      }

      .landing__avatar {
        justify-self: start;
      }
    }

    @media (max-width: 640px) {
      .landing__title {
        font-size: 1.7rem;
        word-break: break-word;
      }
      .landing__lede {
        word-break: break-word;
      }
      .landing__badge {
        font-size: 0.85rem;
      }

      .landing__frame,
      .meta-card,
      .about-card {
        border-radius: 0;
      }
    }
  </style>
</Layout>
