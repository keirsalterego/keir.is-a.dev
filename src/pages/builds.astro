---
import { frontmatter, Content } from "@content/builds/index.md";
import { SITE } from "@config";
import type { BuildItem } from "@types";
import Build from "@components/Build";
import Layout from "@layouts/Layout.astro";

interface Frontmatter {
  builds: Record<string, BuildItem[]>;
}

const { builds } = frontmatter as Frontmatter;
---
<Layout title={`Builds - ${SITE.title}`} activePage="builds">
  <main class="builds-shell">
    <section class="builds-hero">
      <div>
        <p class="eyebrow">/builds</p>
        <h1>The Garage</h1><p class="lede">A wolf on a chase!</p>
      </div>
      <div class="hero-aside">
        <p class="meta-label">Current focus</p>
        <p class="meta-value">Systems engineering & Rust security</p>
      </div>
    </section>

    <section class="builds-note">
      <Content />
    </section>

    <section class="builds-groups">
      {
        Object.keys(builds).map((key) => (
          <article class="group-card">
            <div class="group-header">
              <div>
                <p class="eyebrow">Collection</p>
                <h3>{key}</h3>
              </div>
              <span class="pill pill-ghost">{builds[key].length} builds</span>
            </div>
            <div class="builds-grid">
              {builds[key].map((build) => (
                <Build client:load build={build} />
              ))}
            </div>
          </article>
        ))
      }
    </section>
  </main>
</Layout>

<style>
  .builds-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .builds-hero {
    display: flex;
    justify-content: space-between;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    color: #928374;
    margin: 0 0 0.25rem 0;
  }

  .builds-hero h1 {
    margin: 0;
    font-size: 2.5rem;
    letter-spacing: 0.01em;
  }

  .lede {
    margin: 0.35rem 0 0;
    color: #bdae93;
    max-width: 48rem;
  }

  .hero-aside {
    padding: 1rem 1.1rem;
    border-radius: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    min-width: 220px;
    max-width: 260px;
  }

  .meta-label {
    margin: 0;
    font-size: 0.85rem;
    color: #7c6f64;
  }

  .meta-value {
    margin: 0.2rem 0 0;
    font-weight: 700;
    color: #ebdbb2;
    font-size: 1.05rem;
  }

  .builds-note {
    display: none;
  }

  .builds-note :global(p) {
    color: #d5c4a1;
    margin: 0;
  }

  .builds-groups {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .group-card {
    padding: 0;
    border-radius: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
    margin-bottom: 0.75rem;
  }

  .group-header h3 {
    margin: 0;
    font-size: 1.3rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.32rem 0.65rem;
    border-radius: 0;
    border: none;
    color: #d5c4a1;
    text-decoration: none;
    font-size: 0.9rem;
    background: transparent;
    box-shadow: none;
  }

  .pill-ghost {
    border-color: transparent;
    background: transparent;
    color: #c1ae8b;
    font-size: 0.86rem;
    padding: 0.24rem 0.6rem;
    box-shadow: none;
  }

  .builds-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  @media (max-width: 800px) {
    .builds-hero {
      flex-direction: column;
    }

    .hero-aside {
      width: 100%;
      box-sizing: border-box;
    }

    .group-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
